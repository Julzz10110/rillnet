# Copy to .env for local overrides (optional; Docker Compose sets these inline)

# Config file path (use configs/config.dev.yaml for Redis-backed local dev)
# RILLNET_CONFIG_PATH=configs/config.dev.yaml

RILLNET_JWT_SECRET=dev-only-not-for-production
RILLNET_LOG_LEVEL=debug

# Redis (required when redis.enabled=true in config)
RILLNET_REDIS_ENABLED=true
RILLNET_REDIS_ADDRESS=localhost:6379
# RILLNET_REDIS_PASSWORD=

RILLNET_SERVER_ADDRESS=:8080
RILLNET_SIGNAL_ADDRESS=:8081
